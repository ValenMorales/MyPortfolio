---
import type { AboutHighlight, SkillsGroup } from '../../data/home';

interface Props {
  lead: string;
  paragraphs: string[];
  highlights: AboutHighlight[];
  skills: SkillsGroup[];
}

const { lead, paragraphs, highlights, skills } = Astro.props;
---

<section class="section about" id="about">
  <h2 class="h2">ABOUT ME</h2>
  <div class="about-layout">
    <div class="about-copy">
      <p class="about-lead">{lead}</p>
      {paragraphs.map((text) => <p class="about-text">{text}</p>)}
      <div class="about-actions">
        <a
          href="/CV_Valentina_Morales_Sanchez_go_and_python.pdf"
          class="hero-link hero-link-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          View CV
        </a>
        <a href="#contact" class="hero-link hero-link-secondary">Contact me</a>
      </div>
    </div>
    <div class="about-highlights">
      {
        highlights.map((item) => (
          <article class="about-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </div>

  <div class="skills-panel" aria-label="Core technical skills">
    <h3 class="skills-title">Core Stack</h3>
    <div class="skills-groups">
      {
        skills.map((group) => (
          <div class="skills-group">
            <h4>{group.title}</h4>
            <ul class="skills-list">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
