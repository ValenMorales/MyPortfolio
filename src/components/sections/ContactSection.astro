<section class="contact-section" id="contact">
  <div class="contact-header">
    <h2 class="contact-title">Get In Touch</h2>
    <p class="contact-subtitle">Have a project in mind or want to chat? Feel free to reach out!</p>
  </div>

  <div class="contact-body">
    <!-- Left: info -->
    <div class="contact-info">
      <h3 class="contact-connect">Let's Connect 🤝</h3>
      <p class="contact-description">
        I'm always open to discussing new projects, challenges or engineering opportunities.
        Messages sent through this form will be delivered directly to my inbox.
      </p>

      <div class="contact-detail">
        <span class="contact-icon" aria-hidden="true">✉️</span>
        <div>
          <span class="contact-detail-label">Email</span>
          <a href="mailto:valentinams419@gmail.com" class="contact-detail-value">
            valentinams419@gmail.com
          </a>
        </div>
      </div>

      <div class="contact-detail">
        <span class="contact-icon" aria-hidden="true">🌍</span>
        <div>
          <span class="contact-detail-label">Location</span>
          <span class="contact-detail-value">Manizales, Colombia 📍</span>
        </div>
      </div>
    </div>

    <!-- Right: form -->
    <div class="contact-form-wrap">
      <form action="https://api.web3forms.com/submit" method="POST" class="contact-form">
        <input type="hidden" name="access_key" value="db6d15cd-e0c3-4e72-b5fc-a4e9477b4eeb" />

        <div class="contact-row">
          <div class="contact-field">
            <label for="contact-name">Name</label>
            <input id="contact-name" type="text" name="name" placeholder="Your name" />
          </div>
          <div class="contact-field">
            <label for="contact-email">Email</label>
            <input id="contact-email" type="email" name="email" required placeholder="Your email" />
          </div>
        </div>

        <div class="contact-field contact-field--full">
          <label for="contact-subject">Subject</label>
          <input id="contact-subject" type="text" name="subject" placeholder="Subject" />
        </div>

        <div class="contact-field contact-field--full">
          <label for="contact-message">Message</label>
          <textarea id="contact-message" name="message" required placeholder="Your message"></textarea>
        </div>

        <button type="submit" class="contact-submit">
          Send Message <span aria-hidden="true">✈️</span>
        </button>
      </form>
    </div>
  </div>
</section>
