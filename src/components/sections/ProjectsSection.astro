---
import type { FeaturedProject } from '../../data/home';

interface Props {
  items: FeaturedProject[];
}

const { items } = Astro.props;
---

<section class="my-projects" id="proyectos">
  <h2>Featured Projects</h2>
  <p class="projects-intro">
    Selected projects focused on backend logic, integrations, and product-oriented software
    development.
  </p>
  <div class="projects-grid">
    {
      items.map((project) => (
        <article class="project-card">
          <img src={project.imageSrc} alt={project.imageAlt} />
          <div class="project-card-body">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <ul class="project-tags">
              {project.tags.map((tag) => <li>{tag}</li>)}
            </ul>
            <div class="project-links">
              <a href={project.codeHref} target="_blank" rel="noopener noreferrer">Code</a>
              {project.detailsHref && <a href={project.detailsHref}>Details</a>}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
