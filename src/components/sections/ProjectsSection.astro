---
import type { FeaturedProject } from '../../data/home';

interface Props {
  items: FeaturedProject[];
}

const { items } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const withBase = (href: string) => {
  if (/^(https?:)?\/\//.test(href)) return href;
  if (!href.startsWith('/')) return href;
  if (href.startsWith(base)) return href;
  return `${base}${href.slice(1)}`;
};
---

<section class="my-projects" id="proyectos">
  <h2>Featured Projects</h2>
  <p class="projects-intro">
    Selected projects focused on backend logic, integrations, and product-oriented software
    development.
  </p>
  <div class="projects-grid">
    {
      items.map((project) => (
        <article class="project-card">
          <img src={withBase(project.imageSrc)} alt={project.imageAlt} />
          <div class="project-card-body">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <ul class="project-tags">
              {project.tags.map((tag) => <li>{tag}</li>)}
            </ul>
            <div class="project-links">
              <a href={project.codeHref} target="_blank" rel="noopener noreferrer">Code</a>
              {project.detailsHref && <a href={withBase(project.detailsHref)}>Details</a>}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
