---
import type { HeroData } from '../../data/home';

interface Props {
  hero: HeroData;
}

const { hero } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const withBase = (href: string) => {
  if (/^(https?:)?\/\//.test(href)) return href;
  if (!href.startsWith('/')) return href;
  if (href.startsWith(base)) return href;
  return `${base}${href.slice(1)}`;
};
---

<section class="section info" id="home">
  <div class="hero-copy">
    <p class="eyebrow">{hero.eyebrow}</p>
    <h2 class="h2">{hero.name}</h2>
    <h3 class="h3">{hero.role}</h3>
    <p class="hero-description">{hero.description}</p>
    <div class="hero-actions">
      <a
        href={withBase(hero.cvHref)}
        class="hero-link hero-link-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        View CV
      </a>
      <a
        href={hero.githubHref}
        class="hero-link hero-link-secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
      <a
        href={hero.linkedinHref}
        class="hero-link hero-link-secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        LinkedIn
      </a>
    </div>
  </div>
  <div class="hero-photo">
    <div class="photo-container">
      <!-- anillo exterior que gira (posicionado absolute, no toca la foto) -->
      <div class="photo-ring-outer" aria-hidden="true"></div>
      <!-- foto quieta en el centro -->
      <div class="photo-ring-inner">
        <img src={withBase(hero.photoSrc)} alt={hero.photoAlt} class="photo-img" />
      </div>
    </div>
  </div>
</section>
