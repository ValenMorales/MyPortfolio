---
import type { EducationItem } from '../../data/home';

interface Props {
  items: EducationItem[];
}

const { items } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const withBase = (href: string) => {
  if (/^(https?:)?\/\//.test(href)) return href;
  if (!href.startsWith('/')) return href;
  if (href.startsWith(base)) return href;
  return `${base}${href.slice(1)}`;
};
---

<section class="section education-section" id="educacion">
  <h2 class="h2">Education & Certifications</h2>
  <p class="p">
    Academic background and certifications that support my backend and software engineering work.
  </p>
  <div class="education-list">
    {
      items.map((item) => (
        <article class="education-item">
          <span class="education-badge">{item.badge}</span>
          <div class="education-content">
            <h3>{item.title}</h3>
            <p class="education-org">{item.org}</p>
            <p class="education-date">{item.date}</p>
            <a
              href={withBase(item.pdfHref)}
              class={`education-preview ${item.previewClass}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={item.ariaLabel}
            >
              <img
                src={withBase(item.thumbSrc)}
                class="education-thumb"
                alt={item.thumbAlt}
                loading="lazy"
              />
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>
